# ===== Supabase PostgreSQL (Database) =====
# Supabase → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# ===== Supabase Storage (ไฟล์อัปโหลด: ปก/สลิป/แกลเลอรี/PDF) =====
# Supabase → Project Settings → API
# 🔒 SERVICE KEY เป็นความลับ ใช้ฝั่ง server เท่านั้น ห้ามเผยแพร่/ใส่ฝั่ง client
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_KEY="service_role_key_ที่นี่"
SUPABASE_BUCKET="uploads"

# ===== Auth =====
JWT_SECRET="เปลี่ยนเป็นข้อความสุ่มยาวๆ"
JWT_EXPIRES_IN="7d"

# ===== Server =====
PORT=4000
# โดเมน frontend ที่อนุญาต (CORS) — ใส่หลายอันได้ คั่นด้วย , เช่น https://xxx.vercel.app,https://www.saengdao.com
CLIENT_URL="http://localhost:5173"

# ===== Omise (บัตรเครดิต — ยังไม่เปิดใช้) =====
OMISE_SECRET_KEY=""
OMISE_PUBLIC_KEY=""
