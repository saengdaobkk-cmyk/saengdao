// Prisma schema — Bookstore
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER // ลูกค้า
  STAFF // พนักงาน (เข้าหลังบ้านบางเมนู)
  ADMIN // แอดมินเต็ม
}

// ตั้งค่าร้าน (key-value) เช่น เปิด/ปิด Cart Drawer
model Setting {
  key   String @id
  value String
}

// เมนูนำทางบนหน้าร้าน (จัดการจากหลังบ้าน)
model NavItem {
  id        String   @id @default(uuid())
  label     String
  url       String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ข้อความในเว็บ (จัดการจากหลังบ้าน) — แยกตาม section
model Content {
  key     String @id // เช่น "checkout.title"
  section String // เช่น "checkout"
  label   String // คำอธิบายภาษาไทยว่าช่องนี้คืออะไร
  value   String // ข้อความจริง
  order   Int    @default(0)

  @@index([section])
}

// สไลด์ hero หน้าแรก (จัดการจากหลังบ้าน)
model Slide {
  id        String   @id @default(uuid())
  eyebrow   String? // ข้อความเล็กด้านบน
  title     String // หัวข้อใหญ่ (ขึ้นบรรทัดใหม่ได้)
  subtitle  String?
  ctaText   String? // ข้อความปุ่ม
  ctaLink   String   @default("#catalog")
  image     String? // URL รูปพื้นหลัง
  bgColor   String? // สีพื้นหลัง (ถ้าไม่มีรูป) เช่น #1d1d1f
  dark      Boolean  @default(true) // true = ตัวหนังสือสีขาว
  align     String   @default("center") // แนวนอน: left|center|right
  valign    String   @default("center") // แนวตั้ง: top|center|bottom
  overlay   Int      @default(0) // ความเข้มแผ่นแรเงาบนรูป 0-100 (0=เห็นรูปชัด)
  overlayGradient Boolean @default(false) // แรเงาไล่ระดับจากล่าง (อ่านง่ายบนรูป)
  titleSize       String   @default("md") // ขนาดหัวข้อ: sm|md|lg
  imagePosition   String   @default("center") // โฟกัสรูป: top|center|bottom
  linkUrl         String? // คลิกที่รูป banner ไปที่ URL นี้
  textColor       String? // สีตัวอักษร (override dark)
  buttonColor     String? // สีพื้นปุ่ม CTA
  buttonTextColor String? // สีตัวอักษรปุ่ม
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum DiscountType {
  PERCENT // ลดเป็นเปอร์เซ็นต์
  FIXED // ลดเป็นจำนวนเงิน
}

enum TermType {
  PUBLISHER // สำนักพิมพ์
  AUTHOR // ผู้เขียน
  TRANSLATOR // ผู้แปล
}

// รายชื่อ (collection) ที่จัดการได้ — หนังสือเก็บเป็นข้อความ, Term เป็นแคตตาล็อกให้เลือก
model Term {
  id        String   @id @default(uuid())
  type      TermType
  name      String
  slug      String?
  image     String? // โลโก้ (ใช้กับสำนักพิมพ์ — แสดง marquee หน้าแรก)
  createdAt DateTime @default(now())

  @@unique([type, name])
  @@unique([type, slug])
  @@index([type])
}

// โค้ดส่วนลด
model Coupon {
  id          String       @id @default(uuid())
  code        String       @unique
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)
  minSubtotal Decimal?     @db.Decimal(10, 2) // ยอดขั้นต่ำที่ใช้ได้
  active      Boolean      @default(true)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  address   String? // ที่อยู่จัดส่ง
  // ข้อมูลออกใบเสร็จที่บันทึกไว้
  receiptName    String?
  receiptTaxId   String?
  receiptAddress String?
  role      Role     @default(USER)
  // CRM
  tags      String[]       @default([]) // แท็ก/กลุ่มลูกค้า เช่น VIP, ขายส่ง
  points    Int            @default(0)  // ยอดแต้มสะสมคงเหลือ (สรุปจาก PointEntry)
  orders    Order[]
  crmNotes  CustomerNote[]
  pointLogs PointEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// โน้ต / ประวัติการติดตามลูกค้า (CRM timeline)
model CustomerNote {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body       String
  kind       String   @default("NOTE") // NOTE | CALL | FOLLOWUP
  done       Boolean  @default(false) // สำหรับ FOLLOWUP: ทำแล้วหรือยัง
  dueAt      DateTime? // กำหนดวันติดตาม (FOLLOWUP)
  authorName String? // แอดมินที่บันทึก
  createdAt  DateTime @default(now())

  @@index([userId])
}

// รายการเดินแต้มสะสม (ledger) — ยอดคงเหลืออยู่ที่ User.points
model PointEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int // + ได้แต้ม / - ใช้แต้ม
  reason    String
  orderId   String? // อ้างอิงออเดอร์ (ถ้าได้จากการซื้อ)
  authorName String? // แอดมินที่ปรับ (ถ้าปรับมือ)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id    String  @id @default(uuid())
  name  String  @unique
  slug  String  @unique
  image String? // รูปการ์ดหมวดหมู่ (หน้าแรก)
  books Book[]
}

model Book {
  id            String      @id @default(uuid())
  title         String
  author        String // ผู้เขียน (หลายชื่อคั่นด้วย ,)
  translator    String? // ผู้แปล
  isbn          String?     @unique
  description   String?
  price         Decimal     @db.Decimal(10, 2)
  discountPrice Decimal?    @db.Decimal(10, 2) // ราคาลด
  hotDealPrice  Decimal?    @db.Decimal(10, 2) // ราคา Hot Deal (พิเศษตามช่วงเวลา)
  hotDealStart  DateTime? // เริ่มโปร (เว้นว่าง = เริ่มทันที)
  hotDealEnd    DateTime? // สิ้นสุดโปร (เว้นว่าง = ไม่หมดอายุ)
  stock         Int         @default(0)
  soldCount     Int         @default(0)
  active        Boolean     @default(true) // เปิดขาย (false = ซ่อนจากหน้าร้าน)
  featured      Boolean     @default(false) // แนะนำหน้าแรก
  tags          String[]    @default([]) // แท็ก เช่น ขายดี/ใหม่/แนะนำ
  coverImage    String?
  backCoverImage String? // ปกหลัง
  galleryImages String[]   @default([]) // รูปแกลเลอรี
  previewPdf    String? // ไฟล์ตัวอย่าง PDF (flip book)
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id])
  // ข้อมูลจำเพาะ (Meta)
  publisher     String? // สำนักพิมพ์
  edition       String? // พิมพ์ครั้งที่
  pageCount     Int?
  dimensions    String?
  weight        String?
  paperType     String? // กระดาษเนื้อใน
  coverType     String? // ปกอ่อน/ปกแข็ง
  // รหัส & SEO
  sku           String?
  metaTitle     String?
  metaDescription String?
  slug          String?    @unique
  importedAt    DateTime? // วันที่นำเข้า (จัดลำดับ collection)
  variants      Variant[]
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([categoryId])
  @@index([title])
}

// ตัวเลือกสินค้า เช่น ปกอ่อน/ปกแข็ง/Boxset — แต่ละแบบมีราคา+สต็อกของตัวเอง
model Variant {
  id            String   @id @default(uuid())
  bookId        String
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  name          String
  isbn          String? // ISBN/บาร์โค้ดของตัวเลือกนี้
  coverImage     String? // ปกหน้าเฉพาะตัวเลือกนี้ (เผื่อปกไม่เหมือนกัน)
  backCoverImage String? // ปกหลังเฉพาะตัวเลือกนี้
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  stock         Int      @default(0)
  order         Int      @default(0)

  @@index([bookId])
}

enum OrderStatus {
  PENDING // รอชำระเงิน
  PAID // ชำระแล้ว (รอตรวจ/รอส่ง)
  SHIPPED // จัดส่งแล้ว
  COMPLETED // สำเร็จ
  CANCELLED // ยกเลิก
}

enum PaymentMethod {
  PROMPTPAY // PromptPay QR (สร้างเอง + แนบสลิป)
  CARD // บัตรเครดิต (Omise)
  TRANSFER // โอนเงิน + แนบสลิป
}

enum PaymentStatus {
  UNPAID
  PENDING_REVIEW // แนบสลิปแล้ว รอ admin ยืนยัน
  PAID
  FAILED
}

model Order {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]
  total           Decimal       @db.Decimal(10, 2)
  shippingMethod  String? // ชื่อช่องทางจัดส่ง ณ ตอนสั่ง
  shippingFee     Decimal       @default(0) @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  // ที่อยู่จัดส่ง / ติดต่อ
  shipName        String
  shipPhone       String
  shipAddress     String
  email           String? // อีเมลสำหรับส่งใบยืนยัน
  // ใบเสร็จรับเงิน / ใบกำกับภาษี
  needReceipt     Boolean       @default(false)
  receiptName     String?
  receiptTaxId    String?
  receiptAddress  String?
  // หมายเหตุ + ส่วนลด
  note            String?
  discountCode    String?
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  ruleDiscount    Decimal       @default(0) @db.Decimal(10, 2) // ส่วนลดอัตโนมัติจาก Discount Rules
  ruleName        String? // ชื่อกฎส่วนลดที่ใช้ ณ ตอนสั่ง
  pointsUsed      Int           @default(0) // แต้มที่ลูกค้าใช้แลกส่วนลด
  pointsDiscount  Decimal       @default(0) @db.Decimal(10, 2) // มูลค่าส่วนลดจากแต้ม (บาท)
  cancelledBy     String? // ADMIN | CUSTOMER | SYSTEM (เมื่อ status = CANCELLED)
  cancelledAt     DateTime?
  zortOrderId     String? // id ออเดอร์ใน ZORT หลัง sync
  // การชำระเงิน
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(UNPAID)
  slipImage       String? // URL รูปสลิป (PromptPay/โอนเงิน)
  omiseChargeId   String? // สำหรับบัตรเครดิต
  // ติดตามพัสดุ (ไปรษณีย์ไทย Track & Trace)
  trackingNumber    String? // barcode ไปรษณีย์ เช่น EF667142218TH
  trackingStatus    String? // คำอธิบายสถานะล่าสุด (ไทย)
  trackingStatusDate DateTime? // เวลาของสถานะล่าสุด
  trackingUpdatedAt DateTime? // ครั้งล่าสุดที่ดึงสถานะจาก API
  trackingHistory   Json? // ประวัติสถานะทั้งหมด
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book    @relation(fields: [bookId], references: [id])
  variantId   String? // ตัวเลือกที่เลือก (ถ้ามี)
  variantName String? // ชื่อ variant ณ ตอนซื้อ (เก็บไว้เผื่อ variant ถูกลบ)
  quantity    Int
  price       Decimal @db.Decimal(10, 2) // ราคา ณ ตอนซื้อ

  @@index([orderId])
}

// กฎส่วนลดอัตโนมัติ (คล้าย WooCommerce Discount Rules) — เงื่อนไขระดับตะกร้า
model DiscountRule {
  id            String    @id @default(uuid())
  name          String // เช่น "ซื้อครบ 1000 ลด 10%"
  active        Boolean   @default(true)
  priority      Int       @default(0) // เลขน้อย = สำคัญก่อน (เมื่อส่วนลดเท่ากัน)
  minSubtotal   Decimal   @default(0) @db.Decimal(10, 2) // ยอดซื้อขั้นต่ำ (0 = ไม่กำหนด)
  minQty        Int       @default(0) // จำนวนชิ้นขั้นต่ำ (0 = ไม่กำหนด)
  ruleType      String    @default("CART") // CART | BULK | BOGO
  discountType  String    @default("PERCENT") // PERCENT | FIXED (CART)
  discountValue Decimal   @default(0) @db.Decimal(10, 2)
  maxDiscount   Decimal?  @db.Decimal(10, 2) // เพดานส่วนลด (เฉพาะแบบ %)
  bulkTiers     Json? // BULK: [{ minQty, discountType, discountValue, maxDiscount }]
  buyQty        Int       @default(0) // BOGO: ซื้อ X
  getQty        Int       @default(0) // BOGO: แถม/ลด Y
  getPercent    Int       @default(100) // BOGO: ลด Y กี่ % (100 = ฟรี)
  productScope  String    @default("ALL") // ALL | INCLUDE | EXCLUDE
  productIds    String[]  @default([]) // รายการ book id
  categoryIds   String[]  @default([]) // รายการ category id (นับร่วมกับ productIds)
  startAt       DateTime?
  endAt         DateTime?
  createdAt     DateTime  @default(now())
}

// ช่องทางจัดส่ง — จัดการในหลังร้าน, ลูกค้าเลือกตอน checkout
model ShippingMethod {
  id          String   @id @default(uuid())
  name        String // เช่น "ไปรษณีย์ EMS", "Flash Express"
  fee         Decimal  @default(0) @db.Decimal(10, 2)
  note        String? // เช่น "ส่งถึงใน 1-2 วัน"
  trackingUrl String? // ลิงก์หน้า tracking ของขนส่ง ใส่ {code} แทนเลขพัสดุ
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}
